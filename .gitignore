
# Python bytecode
__pycache__/
*.py[cod]

# Autopus-ADK generated files
.claude/rules/autopus/
.claude/skills/autopus/
.claude/commands/auto.md
.claude/agents/autopus/
.codex/config.toml
.codex/skills/
.gemini/skills/autopus/
.opencode/
.agents/skills/
.agents/plugins/
.autopus/
.autopus/design/imports/
.autopus/runtime/
.mcp.json

# SPEC-REPORT-001 — patient meta files contain PHI (patient_name, birth_date, reg_no, ordering_doctor)
# Auto-generated by ctdna_gui.py meta_scaffold hook; must not be staged by default.
**/meta.json

# SPEC-REPORT-001 follow-up — downstream artifacts that embed PHI from meta.json,
# raw VCFs (cancer-panel genomic data is PHI-class), and tier/annotation CSVs.
# Already-committed files under 0224/, 0325/ are pre-existing repo state and are
# NOT auto-removed by this rule; new outputs are excluded going forward.
**/*_clinical_report.docx
**/*_clinical_report_*.docx
**/*_clinical_report.md
**/*_clinical_report_*.md
**/*_annotated.csv
**/*_tiered_report.csv
**/*.vcf

# Patient DOCX template — the canonical template at repo root contains PHI
# (real patient fill, byte-identical to 0325/template.docx). Pipeline only
# relies on its table/cell structure and overwrites the populated cells;
# the file is treated as a local-only operational artifact, not source.
/template.docx

# Local test artifacts and tooling
.coverage
htmlcov/
